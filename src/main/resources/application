spring.application.name=jobportal

#
# CONFIG FOR DOCKER
#
spring.datasource.url=jdbc:mysql://db:3306/jobportaldb?serverTimezone=UTC&allowPublicKeyRetrieval=true&useSSL=false
spring.datasource.username=jobportal
spring.datasource.password=12345
spring.jpa.hibernate.ddl-auto=update
spring.jpa.open-in-view=false

#
# CONFIG FOR JWT
#
spring.jwt.secret={secret}
spring.jwt.expiration={expiration}

#
# CONFIG MAIL SENDER
#
spring.mail.host={host}
spring.mail.port=587
spring.mail.username={username}
spring.mail.password={password}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
